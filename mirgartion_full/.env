# Access Database
ACCESS_DB_PATH=./DatabaseBig.accdb
OLEDB_PROVIDER=Microsoft.ACE.OLEDB.12.0

# Migration settings
BATCH_SIZE=2000

# Temporary PostgreSQL (port 5433 to avoid conflicts)
PG_HOST=localhost
PG_PORT=5433
PG_DATABASE=access_migration
PG_USER=postgres
PG_PASSWORD=postgres

# Production PostgreSQL (final destination)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mbdatabase"

# pgAdmin (for temporary database viewing)
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
